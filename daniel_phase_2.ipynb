    "classical_hidden, classical_depth = 32, 3\n",
    "for hidden, depth in [(8,2),(12,2),(16,2),(32,2),(64,2),(8,3),(12,3),(16,3),(32,3),(8,4),(12,4),(16,4)]:\n",
    "    p = count_parameters(ClassicalDirectPINN(hidden=hidden, depth=depth))\n",
